// 5. MESSAGE HANDLER (Chat Logic) - OPTIMIZED
// ==========================================
bot.on('message', async (msg) => {
    const chatId = msg.chat.id;
    const userId = msg.from.id;
    const name = msg.from.first_name || "User";
    const text = msg.text;

    // 1. Filter: Hanya proses pesan teks di Private Chat
    if (!text || msg.chat.type !== 'private') return;

    // 2. Command Dasar
    if (text === '/start' || text === '/menu') {
        return await sendMainMenu(chatId, userId, name);
    }

    // 3. Backup Data (Khusus Owner)
    if (text === '/backup' && userId === config.ownerId) {
        if (fs.existsSync(config.userBalanceFile)) await bot.sendDocument(chatId, config.userBalanceFile);
        if (fs.existsSync(config.historyFile)) await bot.sendDocument(chatId, config.historyFile);
        return;
    }

    // --- STATE HANDLER ---
    const state = userState[chatId];
    if (!state) return;

    try {
        // [A] PROSES BELI PAKET
        if (state === 'WAITING_BUY_CODE') {
            const code = text.toUpperCase().trim();
            const res = await axios.get(`https://golang-openapi-packagelist-xltembakservice.kmsp-store.com/v1?api_key=${config.apiKeyKMSP}`);
            const p = res.data.data.find(x => x.package_code === code);
            
            if (!p) return bot.sendMessage(chatId, 'вқҢ *Kode paket tidak ditemukan.*');
            
            const userData = getUserData(userId);
            const markup = userData.role === 'reseller' ? config.markupReseller : config.markupMember;
            const finalPrice = p.package_harga_int + markup;
            
            tempOrder[chatId] = { package_code: code, price_server: p.package_harga_int, price_sell: finalPrice, name: p.package_name };
            userState[chatId] = 'WAITING_BUY_PHONE';
            
            await bot.sendMessage(chatId, `вң… *Paket Terpilih:*\nрҹ“Ұ ${p.package_name}\nрҹ’° Harga: ${formatRupiah(finalPrice)}\n\nKirim *NOMOR TUJUAN* (Contoh: 0878xxx):`, { parse_mode: 'Markdown' });
        }

        else if (state === 'WAITING_BUY_PHONE') {
            let phone = text.replace(/[^0-9]/g, '');
            if (phone.startsWith('08')) phone = '62' + phone.slice(1);
            if (phone.length < 10) return bot.sendMessage(chatId, "вқҢ Nomor tidak valid.");

            const userData = getUserData(userId);
            const order = tempOrder[chatId];
            if (!order) return delete userState[chatId];

            order.phone = phone;
            const sisaSaldo = userData.balance - order.price_sell;
            
            if (sisaSaldo < 0) {
                delete userState[chatId];
                return bot.sendMessage(chatId, `вқҢ *SALDO KURANG*\n\nрҹ’° Harga: *${formatRupiah(order.price_sell)}*\nрҹ’і Saldo: *${formatRupiah(userData.balance)}*`, {
                    parse_mode: 'Markdown',
                    reply_markup: { inline_keyboard: [[{ text: 'вһ• Topup', callback_data: 'menu_topup' }], [{ text: 'рҹҸ  Menu', callback_data: 'back_to_menu' }]] }
                });
            }
            
            delete userState[chatId];
            const receipt = `рҹ§ҫ *KONFIRMASI PEMBELIAN*\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nрҹ“Ұ *Produk* : ${order.name}\nрҹ“ұ *Nomor* : \`${order.phone}\`\nрҹ’° *Harga* : *${formatRupiah(order.price_sell)}*\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nрҹ’і *Saldo* : ${formatRupiah(userData.balance)}\nрҹ“ү *Sisa* : _${formatRupiah(sisaSaldo)}_`;
            
            await bot.sendMessage(chatId, receipt, {
                parse_mode: 'Markdown',
                reply_markup: { inline_keyboard: [[{ text: 'вң… BAYAR SEKARANG', callback_data: 'confirm_buy' }], [{ text: 'вқҢ BATAL', callback_data: 'back_to_menu' }]] }
            });
        }

        // [B] PROSES TOPUP
        else if (state === 'WAITING_TOPUP_AMOUNT') {
            const nominal = parseInt(text.replace(/[^0-9]/g, ''));
            if (isNaN(nominal) || nominal < 1000) return bot.sendMessage(chatId, "вқҢ Minimal Topup Rp 1.000");

            delete userState[chatId];
            const loading = await bot.sendMessage(chatId, "вҸі *Menyiapkan QRIS...*", { parse_mode: 'Markdown' });

            try {
                const res = await axios.get(`https://my-payment.autsc.my.id/api/deposit`, { 
                    params: { amount: nominal, apikey: config.apiKeyPayment } 
                });

                await bot.deleteMessage(chatId, loading.message_id).catch(() => {});

                if (res.data.status === 'success') {
                    const payData = res.data.data;
                    tempOrder[chatId] = { type: 'topup', trx_id: payData.id, amount_added: nominal };

                    await bot.sendPhoto(chatId, payData.qris_url, {
                        caption: `рҹ’і *TAGIHAN TOPUP*\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nрҹҶ” *ID* : \`${payData.id}\`\nрҹ’° *Total* : *${formatRupiah(payData.total_amount)}*\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n1. Scan QRIS di atas\n2. Masukkan nominal sesuai total\n3. Saldo masuk otomatis.`,
                        parse_mode: 'Markdown',
                        reply_markup: { inline_keyboard: [[{ text: 'рҹ”„ Cek Status', callback_data: 'check_payment' }], [{ text: 'рҹ”ҷ Batal', callback_data: 'back_to_menu' }]] }
                    });
                } else {
                    bot.sendMessage(chatId, "вқҢ Layanan pembayaran offline.");
                }
            } catch (e) {
                bot.sendMessage(chatId, "вқҢ Gagal membuat pembayaran.");
            }
        }

        // [C] FITUR XL (OTP & LOGIN)
        else if (state === 'WAITING_XL_PHONE') {
            let phone = text.replace(/[^0-9]/g, '');
            if (phone.startsWith('0')) phone = '62' + phone.slice(1);
            
            await bot.sendMessage(chatId, 'вҸі *Mengirim OTP...*');
            try {
                const res = await axios.get(`https://golang-openapi-reqotp-xltembakservice.kmsp-store.com/v1`, {
                    params: { api_key: config.apiKeyKMSP, phone: phone, method: 'OTP' }
                });
                if (res.data.status) {
                    tempOrder[chatId] = { auth_id: res.data.data.auth_id, phone: phone };
                    userState[chatId] = 'WAITING_XL_OTP';
                    await bot.sendMessage(chatId, 'вң… *OTP Dikirim!*\nMasukkan kode dari SMS:');
                } else {
                    delete userState[chatId];
                    await bot.sendMessage(chatId, `вқҢ Gagal: ${res.data.message}`);
                }
            } catch (e) { bot.sendMessage(chatId, "вқҢ Gangguan server OTP."); }
        }
        else if (state === 'WAITING_XL_OTP') {
            const dataLogin = tempOrder[chatId];
            if (!dataLogin) return delete userState[chatId];
            
            try {
                const res = await axios.get(`https://golang-openapi-login-xltembakservice.kmsp-store.com/v1`, {
                    params: { api_key: config.apiKeyKMSP, phone: dataLogin.phone, method: 'OTP', auth_id: dataLogin.auth_id, otp: text.trim() }
                });
                if (res.data.status) {
                    xlSessions[userId] = { phone: dataLogin.phone, access_token: res.data.data.access_token };
                    saveDB(config.xlSessionsFile, xlSessions);
                    delete userState[chatId]; delete tempOrder[chatId];
                    await bot.sendMessage(chatId, 'вң… *LOGIN XL BERHASIL!*');
                } else {
                    await bot.sendMessage(chatId, 'вқҢ OTP Salah.');
                }
            } catch (e) { bot.sendMessage(chatId, "вқҢ Gagal login."); }
        }

        // [D] OWNER FLOW (BROADCAST & SALDO)
        else if (state === 'OWNER_WAITING_BC_TEXT') {
            delete userState[chatId];
            const users = Object.keys(userBalance);
            await bot.sendMessage(chatId, `рҹҡҖ Memulai BC ke ${users.length} user...`);
            
            users.forEach((uid, idx) => {
                setTimeout(() => {
                    bot.sendMessage(uid, `рҹ“ў *PENGUMUMAN*\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n${text}`, { parse_mode: 'Markdown' })
                    .catch(() => {});
                }, idx * 100); 
            });
        }
        else if (state === 'OWNER_WAITING_ID_ADD') {
            const tId = text.trim();
            if (!userBalance[tId]) return bot.sendMessage(chatId, "вқҢ ID tidak ditemukan.");
            tempOrder[chatId] = { targetId: tId };
            userState[chatId] = 'OWNER_WAITING_AMOUNT_ADD';
            bot.sendMessage(chatId, "рҹ’° Masukkan nominal saldo:");
        }
        else if (state === 'OWNER_WAITING_AMOUNT_ADD') {
            const amount = parseInt(text);
            const tId = tempOrder[chatId]?.targetId;
            if (isNaN(amount) || !tId) return bot.sendMessage(chatId, "вқҢ Error.");
            
            userBalance[tId].balance += amount;
            saveDB(config.userBalanceFile, userBalance);
            delete userState[chatId];
            bot.sendMessage(chatId, `вң… Berhasil +${formatRupiah(amount)} ke ${tId}`);
            bot.sendMessage(tId, `рҹҺҒ Saldo ditambahkan Admin: ${formatRupiah(amount)}`);
        }
        // [E] FITUR CEK KUOTA
        else if (state === 'WAITING_CHECK_QUOTA') {
            let phone = text.replace(/[^0-9]/g, '');
            if (phone.startsWith('08')) phone = '62' + phone.slice(1);
            
            delete userState[chatId]; // Langsung hapus state agar tidak looping
            await bot.sendMessage(chatId, 'рҹ”Қ *Sedang mengecek kuota ke server...*', { parse_mode: 'Markdown' });

            try {
                const res = await axios.get(`https://apigw.kmsp-store.com/sidompul/v4/cek_kuota`, { 
                    params: { msisdn: phone, isJSON: 'true' }, 
                    headers: { 
                        "Authorization": config.sidompulAuth, 
                        "X-API-Key": config.sidompulKey,
                        "X-App-Version": "4.0.0" 
                    },
                    timeout: 20000 // Beri timeout agak lama karena server provider sering delay
                });

                if (res.data.status && res.data.data.hasil) {
                    const hasil = res.data.data.hasil
                        .replace(/<br>/g, "\n")
                        .replace(/рҹ“ғ RESULT:/g, "рҹ“Ҡ *HASIL CEK KUOTA*")
                        .replace(/------------------------/g, "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ");
                    
                    await bot.sendMessage(chatId, hasil, { 
                        parse_mode: 'Markdown',
                        reply_markup: { inline_keyboard: [[{ text: 'рҹҸ  Menu Utama', callback_data: 'back_to_menu' }]] }
                    });
                } else {
                    await bot.sendMessage(chatId, 'вқҢ *Data tidak ditemukan.*\nNomor salah atau sedang gangguan server.');
                }
            } catch(e) { 
                console.error("Cek Kuota Error:", e.message);
                bot.sendMessage(chatId, 'вқҢ *Gagal terhubung ke provider.*'); 
            }
        }
        
        // [F] FITUR CEK AKRAB
        else if (state === 'WAITING_CEK_AKRAB') {
            let phone = text.replace(/[^0-9]/g, '');
            if (phone.startsWith('08')) phone = '62' + phone.slice(1);
            
            delete userState[chatId];
            await bot.sendMessage(chatId, 'рҹ”Қ *Sedang mengecek status paket Akrab...*', { parse_mode: 'Markdown' });

            try {
                const res = await axios.get(`https://apigw.kmsp-store.com/sidompul/v4/cek_akrab`, { 
                    params: { msisdn: phone, isJSON: 'true' }, 
                    headers: { 
                        "Authorization": config.sidompulAuth, 
                        "X-API-Key": config.sidompulKey,
                        "X-App-Version": "4.0.0" 
                    },
                    timeout: 20000
                });

                if (res.data.status && res.data.data.hasil) {
                    const hasil = res.data.data.hasil
                        .replace(/<br>/g, "\n")
                        .replace(/рҹ“ғ RESULT:/g, "рҹ“Ҡ *HASIL CEK AKRAB*")
                        .replace(/------------------------/g, "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ");
                    
                    await bot.sendMessage(chatId, hasil, { 
                        parse_mode: 'Markdown',
                        reply_markup: { inline_keyboard: [[{ text: 'рҹҸ  Menu Utama', callback_data: 'back_to_menu' }]] }
                    });
                } else {
                    await bot.sendMessage(chatId, 'вқҢ *Data tidak ditemukan.*');
                }
            } catch(e) { 
                bot.sendMessage(chatId, 'вқҢ *Gagal terhubung ke provider.*'); 
            }
        }

    } catch (e) {
        console.error("Handler Error:", e.message);
        delete userState[chatId];
        bot.sendMessage(chatId, "вқҢ Terjadi gangguan sementara.");
    }
});

// ==========================================
