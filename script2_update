clearcache\
;;
}' "$MENU_FILE"

# 4. Fix any potential formatting issues

sed -i 's/╭════════════════╮╭══════════════════╮╭════════════════════╮/╭════════════════╮╭══════════════════╮╭════════════════════╮/' "$MENU_FILE"
