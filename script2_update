a\
echo -e "${COLOR1} │  ${WH} [${COLOR1}98${WH}]${NC}${COLOR1}• ${WH} VPN   ${WH}[${GREEN}GOOD${WH}]${NC}${COLOR1}    | ${NC}${WH} [${COLOR1}99${WH}]${NC}${COLOR1}• ${WH} TROJANGO   ${WH}[${GREEN}GOOD${WH}]${NC} "
}' "$MENU_FILE"

# 3. Add case handler in CORRECT position - AFTER option 8
sed -i '/^6 | 06)/,/;;/ {
  /;;/ a\
\
98)\
clear\
vpn\
;;
}' "$MENU_FILE"

sed -i '/^13 | 013)/,/;;/ {
  /;;/ a\
\
99)\
